# AWS — auto-populated when running on Lambda/Amplify via IAM role
# For local dev, create an IAM user with DynamoDB access and fill these in
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB table names (must match CDK stack)
DYNAMODB_VIDEOS_TABLE=tw-videos
DYNAMODB_SUBSCRIBERS_TABLE=tw-subscribers

# Public API URL (set after CDK deploy)
NEXT_PUBLIC_API_URL=https://YOUR_API_GATEWAY_URL/prod

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
